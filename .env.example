# Planex V2 — required environment variables (NO real values committed).
# Backend (Django) and Frontend (Next) are deployed as ONE Railway service.

# ── Django ───────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-app.up.railway.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
DJANGO_LOG_LEVEL=INFO

# ── Database (Railway injects DATABASE_URL automatically) ────────────────
DATABASE_URL=
DB_SSL_REQUIRE=True
DB_CONN_MAX_AGE=600

# ── Auth / JWT cookies ──────────────────────────────────────────────────
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# ── CORS (same-origin in prod via Next proxy; set for safety) ────────────
CORS_ALLOWED_ORIGINS=https://your-app.up.railway.app

# ── Platform seed (run once via: manage.py seed_platform) ────────────────
SUPERADMIN_EMAIL=superadmin@planex.app
SUPERADMIN_PASSWORD=

# ── Cloudflare R2 (S3-compatible object storage) — provided later ────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT_URL=
R2_PRESIGNED_URL_EXPIRY=900
MAX_UPLOAD_BYTES=10485760

# ── Frontend (Next.js) ──────────────────────────────────────────────────
# Internal Django address Next proxies /api to (same container in prod).
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
# Public API base for the browser (same-origin path).
NEXT_PUBLIC_API_URL=/api
PORT=3000
